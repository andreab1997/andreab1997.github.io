---
// ResearchCard
const { num, title, venue, abstract, arxhref} = Astro.props;
---

<div class="pub-item">
    <div class="pub-num">— {num}</div>
    <div>
        <div class="pub-title">{title}</div>
        <div class="pub-venue">{venue}</div>
        <div class="pub-abstract">{abstract}</div>
    </div>
    <div class="pub-links">
        <a href={arxhref} class="icon-link" target="_blank">arX</a>
    </div>
</div>


<style>
  .pub-item {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 24px;
    align-items: start;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
    }

  .pub-item:first-child { border-top: 1px solid var(--border); }

  .pub-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    padding-top: 3px;
  }

  .pub-title {
    font-family: var(--display);
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: -0.2px;
    line-height: 1.3;
  }

  .pub-venue {
    font-size: 12px;
    color: var(--text-muted);
    font-family: var(--mono);
    margin-bottom: 10px;
  }

  .pub-abstract {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 600px;
  }

  .pub-links {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

</style>