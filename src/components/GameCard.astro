---
// GameCard
const { title, description, emoji, href, tags } = Astro.props;
---

<a href={href} class="game-card" target="_blank">
  <div class="game-card-bg">
    <img src={emoji} alt="Screenshot"/>
  </div>
  <div class="game-card-inner">
    <div class="game-card-title">{title}</div>
    <div class="game-card-desc">{description}</div>
    <div class="game-card-meta">
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
  <div class="game-card-arrow">↗</div>
</a>

<style>
  .game-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.3s;
    text-decoration: none;
    display: block;
    aspect-ratio: 16/9;
  }
  .game-card:hover { border-color: var(--border-bright); }

  .game-card-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0
  }

  .game-card-bg img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.4;
}

  .game-card:hover .game-card-bg {
    opacity: 0.1;
    transform: scale(1.05);
  }

  .game-card-inner {
    position: absolute;
    inset: 0;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(to top, rgba(10,10,12,0.95) 0%, rgba(10,10,12,0.4) 50%, transparent 100%);
  }

  .game-card-tag {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
    font-family: var(--mono);
  }

  .game-card-title {
    font-family: var(--display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.1;
  }

  .game-card-desc {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
    max-width: 340px;
  }

  .game-card-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--border-bright);
    font-family: var(--mono);
    color: #d1d5db;
  }

  .tag.green { border-color: var(--green); color: var(--green); background: var(--green-dim); }
  .tag.amber { border-color: var(--amber); color: var(--amber); background: var(--amber-dim); }
  .tag.accent { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

  .game-card-arrow {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-bright);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 16px;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .game-card:hover .game-card-arrow {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* ─── GAME CARD COLORS ─── */
  .game-card.astro .game-card-bg { color: var(--amber); }
  .game-card.space .game-card-bg { color: var(--accent); }
  .game-card.puzzle .game-card-bg { color: var(--green); }
  .game-card.action .game-card-bg { color: var(--red); }
</style>